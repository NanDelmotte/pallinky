{
  "name": "pallinky-root",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "android": "npm run android --workspace=apps/mobile",
    "ios": "npm run ios --workspace=apps/mobile",
    "mobile": "npm run mobile --workspace=apps/mobile",
    "build:ios:development": "npm run build:ios:development --workspace=apps/mobile",
    "build:ios:production": "npm run build:ios:production --workspace=apps/mobile",
    "build:android:development": "npm run build:android:development --workspace=apps/mobile",
    "build:android:production": "npm run build:android:production --workspace=apps/mobile",
    "web": "npm run dev:development --workspace=apps/web --",
    "web:development": "npm run dev:development --workspace=apps/web --",
    "web:production": "npm run dev:production --workspace=apps/web --",
    "build:web": "npm run build:production --workspace=apps/web",
    "build:web:development": "npm run build:development --workspace=apps/web --",
    "build:web:production": "npm run build:production --workspace=apps/web --"
  },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native-svg": "15.15.3"
  },
  "dependencies": {
    "expo": "~55.0.17",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-svg": "15.15.3"
  }
}
